rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth.uid == userId;
      // Allow own profile updates AND allow others to update followers array
      allow update: if request.auth.uid == userId ||
        (request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['followers', 'following']));
      allow delete: if false;
    }

    // ── Trades ────────────────────────────────────────────
    match /trades/{tradeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['likedBy', 'likes', 'commentCount', 'status'])
      );
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow delete: if request.auth != null &&
          request.auth.uid == resource.data.userId;
        allow update: if request.auth != null &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likedBy', 'likes']);

        match /replies/{replyId} {
          allow read: if true;
          allow create: if request.auth != null;
          allow delete: if request.auth != null &&
            request.auth.uid == resource.data.userId;
          allow update: if false;
        }
      }
    }

    // ── Chats (1-on-1 real-time messaging) ───────────────
    // chatId = sorted([uid1, uid2]).join('_')
    match /chats/{chatId} {

      allow read: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants &&
        request.resource.data.participants.size() == 2;

      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants;

      allow delete: if false;

      // ── Messages sub-collection ──────────────────────
      match /messages/{messageId} {

        function participants() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        }

        allow read: if request.auth != null &&
          request.auth.uid in participants();

        allow create: if request.auth != null &&
          request.auth.uid in participants() &&
          request.resource.data.senderId == request.auth.uid &&
          request.resource.data.text is string &&
          request.resource.data.text.size() > 0 &&
          request.resource.data.text.size() <= 2000;

        // Only allow flipping read flag
        allow update: if request.auth != null &&
          request.auth.uid in participants() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);

        allow delete: if false;
      }
    }

    // ── Legacy conversations (backward compat) ────────────
    match /conversations/{convoId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.userIds;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.userIds;
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.userIds;

      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convoId)).data.userIds;
        allow create: if request.auth != null &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convoId)).data.userIds &&
          request.resource.data.sender_id == request.auth.uid;
        allow update: if request.auth != null &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convoId)).data.userIds;
        allow delete: if false;
      }
    }

    // ── Notifications ──────────────────────────────────────
    match /notifications/{notifId} {
      allow read, update, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
  }
}
